# Transmitted via Ansible - Do not edit manually

# 1. JSON-Parsing-Modul laden
module(load="mmjsonparse")

# 2. Inputs (Parameter kleingeschrieben)
input(type="imuxsock" Socket="/var/run/sshd/dev/log" CreatePath="on")
input(type="imuxsock" Socket="/run/systemd/journal/syslog")

# 3. Manuelles GELF-JSON-Template definieren
template(name="GELF_Format" type="string"
         string="{\"version\":\"1.1\",\"host\":\"%HOSTNAME%\",\"short_message\":\"%msg:::json%\",\"timestamp\":%timereported:::date-unixtimestamp%,\"level\":%syslogseverity%,\"_env\":\"{{ rsyslog_tag_env | default('production') }}\",\"_role\":\"{{ rsyslog_tag_role | default('generic') }}\",\"_layer\":\"{{ rsyslog_tag_layer | default('os') }}\",\"_managed_by\":\"ansible\",\"_app_name\":\"%APP-NAME%\",\"_proc_id\":\"%PROCID%\"}\n")

# 4. Senden via omfwd (Standard-Forwarding) an den Graylog GELF-Input
*.* action(
    type="omfwd"
    target="{{ rsyslog_graylog_target }}"
    port="{{ rsyslog_graylog_port | default(12201) }}"
    protocol="{{ rsyslog_graylog_protocol | default('udp') }}"
    template="GELF_Format"

    # Queue-Schutz
    action.resumeRetryCount="-1"
    queue.type="linkedList"
    queue.size="50000"
    queue.discardmark="45000"
    queue.discardseverity="6"
    queue.saveonshutdown="on"
)